# ── Externalized secrets (P2-1) ─────────────────────────────────────────────
# Copy this file to `.env` (gitignored) and fill in real values, OR set these
# as real environment variables. They feed the ${...} placeholders in
# application-ubuntu.yml / application-local.yml.
#
# How each environment consumes them:
#   • Server (ubuntu profile): docker-compose auto-loads dream-app/.env and
#     injects it into the container via `env_file:` → Spring resolves them.
#   • Local dev (local profile): set them in your IDE run configuration's
#     env vars, or `export` them in the shell before `mvn spring-boot:run`
#     (Spring Boot does NOT auto-read .env files).
#
# SECURITY NOTE: the three datastores currently share one password — a smell.
# When rotating the leaked value, give each store a DISTINCT secret.

# MySQL
DB_USERNAME=epoch
DB_PASSWORD=change-me

# Redis
REDIS_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USERNAME=epoch
RABBITMQ_PASSWORD=change-me
